<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Диалоговые окна"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnAlertDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AlertDialog"
        android:onClick="onClickAlertDialog"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnTimeDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TimePickerDialog"
        android:onClick="onClickTimeDialog"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnDateDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DatePickerDialog"
        android:onClick="onClickDateDialog"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnProgressDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ProgressDialog"
        android:onClick="onClickProgressDialog"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/textViewResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Результат появится здесь"
        android:textSize="16sp"
        android:padding="16dp"/>

</LinearLayout>